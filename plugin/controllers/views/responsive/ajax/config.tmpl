#from Plugins.Extensions.OpenWebif.controllers.i18n import tstrings

#def select($config)
<div class="row clearfix">
	<div class="col-xs-5 align-right" style="padding-top:8px">
		<label>$config.description</label>
	</div>
	<div class="col-xs-5">
		<select class="form-control show-tick" id="$config.path" data-config-type="select" onchange="updateConfig('$config.path', this.value, '$key');">
			#for $choice in $config.data.choices
				#if str($config.data.current) == str($choice[0])
					<option value="$choice[0]" selected="true">$choice[1]</option>
				#else
					<option value="$choice[0]">$choice[1]</option>
				#end if
			#end for
		</select>
	</div>
</div>
#end def

#def checkbox($config)
<div class="row clearfix">
	<div class="col-xs-5 align-right" style="padding-top:8px">
		<label>$config.description</label>
	</div>
	<div class="col-xs-5">
		<div class="switch switch-col-indigo">
		#if $config.data.current
			<label>
				<input type="checkbox" name="$config.path" id="$config.path" data-config-type="checkbox" checked="checked" onclick="updateConfig('$config.path', this.checked, '$key');">
				<span class='lever switch--skinned'></span>
			</label>
		#else
			<label>
				<input type="checkbox" name="$config.path" id="$config.path" data-config-type="checkbox" onclick="updateConfig('$config.path', this.checked, '$key');">
				<span class='lever switch--skinned'></span>
			</label>
		#end if
		</div>
		<label for="$config.path"></label>
	</div>
</div>
#end def

#def multicheckbox($config)
<div class="row clearfix">
	<div class="col-xs-5 align-right" style="padding-top:8px">
		<label>$config.description</label>
	</div>
	<div class="col-xs-5">
	#for $choice in $config.data.choices
		#if $choice in $config.data.current
			<input type="checkbox" id="${config.path}_${choice}" data-config-type="multicheckbox" data-config-group="$config.path" class="form-control chk--skinned" checked="checked" onclick="updateConfig('$config.path', $choice, '$key');">
		#else
			<input type="checkbox" id="${config.path}_${choice}" data-config-type="multicheckbox" data-config-group="$config.path" class="form-control chk--skinned" onclick="updateConfig('$config.path', $choice, '$key');">
		#end if
			<label for="${config.path}_${choice}">$choice</label>
	#end for
	</div>
</div>
#end def

#def number($config)
<div class="row clearfix">
	<div class="col-xs-5 align-right" style="padding-top:8px">
		<label>$config.description</label>
	</div>
	<div class="col-xs-5">
		<div class="form-line">
			<input type="number" name="${config.path}" id="${config.path}" data-config-type="number" value="$config.data.current" placeholder="$config.data.current" class="form-control" onkeydown="numberTextboxKeydownFilter(event);" onchange="updateConfig('$config.path', this.value, '$key');">
		</div>
	</div>
</div>
#end def

#def text($config)
<div class="row clearfix">
	<div class="col-xs-5 align-right" style="padding-top:8px">
		<label>$config.description</label>
	</div>
	<div class="col-xs-5">
		<div class="form-line">
			<input type="text" name="${config.path}" id="${config.path}" data-config-type="text" value="$config.data.current" class="form-control" onchange="updateConfig('$config.path', this.value, '$key');">
		</div>
	</div>
</div>
#end def

<div id="content_main">
	<div style="display:none" id="thistitleconfig">
		<i class='material-icons material-icons-centered'>settings</i>
		$tstrings['settings'] - $title
	</div>
	<div class="form-group" id="configuration">
		#for $config in $configs:
			#if $config.data.type == "select"
				$select($config)
			#elif $config.data.type == "checkbox"
				$checkbox($config)
			#elif $config.data.type == "multicheckbox"
				$multicheckbox($config)
			#elif $config.data.type == "number"
				$number($config)
			#elif $config.data.type == "text"
				$text($config)
			#elif $config.data.type == "slider"
				$number($config)
			#end if
		#end for
	</div>
	<div style="margin-top: 15px; padding: 10px; text-align: right;">
		<button id="btn_cancel" class="btn btn-default" style="margin-right: 10px;">$tstrings['cancel']</button>
		<button id="btn_save" class="btn btn-primary">$tstrings['save']</button>
	</div>
</div>

<script>
	jQuery("#configtitle").html(jQuery('#thistitleconfig').html());
	jQuery.AdminBSB.input.activate();
	jQuery.AdminBSB.select.activate();
	jQuery('#btn_save').click(function() {
		saveAllConfig('$key');
	});
	jQuery('#btn_cancel').click(function() {
		cancelAllConfig('$key');
	});
</script>
