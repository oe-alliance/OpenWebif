#from Plugins.Extensions.OpenWebif.controllers.i18n import tstrings
#def select($config)
<tr>
<td>$config.description</td>
<td>
	<select id="$config.path" data-config-type="select">
		#for $choice in $config.data.choices
			#if str($config.data.current) == str($choice[0])
				<option value="$choice[0]" selected="true">$choice[1]</option>
			#else
				<option value="$choice[0]">$choice[1]</option>
			#end if
		#end for
	</select>
</td>
</tr>
#end def

#def checkbox($config)
<tr>
<td>$config.description</td>
<td>
	#if $config.data.current
		<input type="checkbox" id="$config.path" data-config-type="checkbox" checked="true" />
	#else
		<input type="checkbox" id="$config.path" data-config-type="checkbox" />
	#end if
</td>
</tr>
#end def

#def multicheckbox($config)
<tr>
<td>$config.description</td>
<td>
	#for $choice in $config.data.choices
		#if $choice in $config.data.current
			<input type="checkbox" id="${config.path}_${choice}" data-config-type="multicheckbox" data-config-group="$config.path" checked="true" />
		#else
			<input type="checkbox" id="${config.path}_${choice}" data-config-type="multicheckbox" data-config-group="$config.path" />
		#end if
		$choice
	#end for
</td>
</tr>
#end def

#def number($config)
<tr>
<td>$config.description</td>
<td>
	<input type="text" id="${config.path}" data-config-type="number" value="$config.data.current" onkeydown="numberTextboxKeydownFilter(event);">
</td>
</tr>
#end def

#def text($config)
<tr>
<td>$config.description</td>
<td>
	<input type="text" id="${config.path}" data-config-type="text" value="$config.data.current">
</td>
</tr>
#end def

<div id="content_main">
	<h3 class="ui-widget-header">$title</h3>
	<table id="configuration">
		#for $config in $configs:
			#if $config.data.type == "select"
				$select($config)
			#elif $config.data.type == "checkbox"
				$checkbox($config)
			#elif $config.data.type == "multicheckbox"
				$multicheckbox($config)
			#elif $config.data.type == "number"
				$number($config)
			#elif $config.data.type == "text"
				$text($config)
			#elif $config.data.type == "slider"
				$number($config)
			#end if
		#end for
	</table>
	<div style="margin-top: 15px; padding: 10px; text-align: right;">
		<button id="btn_reset" class="ui-button ui-widget ui-corner-all" style="margin-right: 10px;">$tstrings['form_reset']</button>
		<button id="btn_save" class="ui-button ui-widget ui-corner-all ui-button-primary">$tstrings['save']</button>
	</div>
</div>

<script type="text/javascript">
\$(document).ready(function() {
	\$('#btn_save').click(function() {
		saveAllConfig('$key');
	});
	\$('#btn_reset').click(function() {
		location.reload();
	});
});
</script>
